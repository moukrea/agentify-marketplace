{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/moukrea/agentify-marketplace/blob/main/plugins/agentify/prd-schema.json",
  "title": "agentify-prd",
  "description": "Logical shape of a PRD. The markdown task-backend driver encodes this as YAML front-matter + H2 sections; non-markdown drivers map fields onto backend objects (Jira Epic fields, Notion DB columns, Linear project fields).",
  "type": "object",
  "additionalProperties": false,
  "required": ["prd_id", "title", "state", "user_stories", "functional_requirements", "acceptance_criteria"],
  "properties": {
    "prd_id":       { "type": "string", "pattern": "^[0-9]{4}-[a-z0-9-]+$" },
    "title":        { "type": "string", "minLength": 1 },
    "state":        { "type": "string", "enum": ["draft", "clarified", "approved", "implemented", "cancelled"] },
    "backend_ref":  { "type": "string" },
    "created_at":   { "type": "string", "format": "date-time" },
    "last_updated_at": { "type": "string", "format": "date-time" },
    "user_stories": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "functional_requirements": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "non_functional_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "description": "Falsifiable check. The /<prefix>-prd skill rejects PRDs whose AC entries contain 'looks good', 'works', 'ok', 'nice', 'clean', 'clear' as standalone words."
      }
    }
  }
}
