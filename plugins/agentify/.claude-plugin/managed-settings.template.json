{
  "$schema": "https://json.schemastore.org/claude-code-managed-settings.json",
  "_comment": "Template for /etc/claude-code/managed-settings.json (admin-deployed). Substitute {__AGT_*__} placeholders at agentification time via bin/agentify (resolves marketplace.host_pattern_regex and skills.prefix from agentify.config.json). Engineers deploy this template post-substitution. Adapted from AGENTIFY.md §12.14.",
  "permissions": {
    "deny": [
      "Read(./.env*)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.pem.*)",
      "Read(**/*.key)",
      "Read(**/*.key.*)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/credentials*)",
      "Edit(./.env*)",
      "Edit(**/.env*)",
      "Edit(**/secrets/**)",
      "Edit(.git/**)",
      "Edit(**/*.lock)",
      "Edit(**/package-lock.json)",
      "Edit(**/pnpm-lock.yaml)",
      "Edit(**/yarn.lock)",
      "Edit(**/Cargo.lock)",
      "Edit(**/composer.lock)",
      "Edit(**/uv.lock)",
      "Edit(**/poetry.lock)",
      "Edit(**/Pipfile.lock)",
      "Edit(**/go.sum)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push --mirror*)",
      "Bash(git reset --hard *origin*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo *)"
    ]
  },
  "disableBypassPermissionsMode": "disable",
  "allowManagedHooksOnly": true,
  "allowManagedPermissionRulesOnly": true,
  "strictKnownMarketplaces": [
    {
      "source": "hostPattern",
      "hostPattern": "^{__AGT_MARKETPLACE_HOST_REGEX__}$"
    }
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/protect-files.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/repo-boundary.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/guard-bash.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/conventional-commit.sh" }
        ]
      }
    ]
  }
}
